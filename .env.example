# ──────────── Database ────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=scg_v2
DB_USER=postgres
DB_PASSWORD=postgres
DB_MAX_CONNECTIONS=20
# DB_IDLE_TIMEOUT_MS=30000
# DB_CONNECTION_TIMEOUT_MS=5000
# DB_SLOW_QUERY_MS=500
# Maximum time (ms) a single SQL statement may run before being killed.
# Prevents runaway queries from locking the database.
# DB_STATEMENT_TIMEOUT_MS=30000

# ──────────── Server ────────────
SCG_PORT=3100
SCG_HOST=0.0.0.0
NODE_ENV=production

# ──────────── Authentication ────────────
# Comma-separated API keys. If empty, ALL requests are rejected (fail-closed).
SCG_API_KEYS=your-secret-key-here

# ──────────── Security ────────────
# Comma-separated allowed repository base paths. Repos outside these paths are rejected.
# SCG_ALLOWED_BASE_PATHS=/home/repos,/var/projects

# Comma-separated CORS origins. If empty, no CORS headers are emitted (fail-closed).
# SCG_CORS_ORIGINS=http://localhost:3000,https://your-frontend.example.com

# ──────────── Logging ────────────
# debug | info | warn | error | fatal
LOG_LEVEL=info
